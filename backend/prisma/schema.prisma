// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//============ Models ============//

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // @OneToMany -> A User has many Bookings
  bookings Booking[]

  // @OneToMany -> A User can leave many Reviews
  reviews Review[]
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  startDate DateTime @default(now())
  endDate   DateTime @default(now())
  status    BookingStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  car  Car  @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}

model Brand {
  id    String   @id @default(cuid())
  name  String   @unique
  image String

  cars Car[]
}

model Car {
  id           String   @id @default(cuid())
  brandId      String
  model        String   @unique
  slug         String   @unique
  year         Int
  pricePerDay  Int    @default(0)
  doors        Int      @default(2)
  seats        Int      @default(2)
  image        String
  features     String[] @default([])
  status       CarStatus
  transmission Transmission @default(MANUAL)
  carType      CarType
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // @OneToMany -> A Brand has many Cars
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  // @OneToMany -> A Car has many Bookings
  bookings Booking[]

  // @OneToMany -> A Car has many Reviews
  reviews Review[]
}

model Review {
  id        String   @id @default(cuid())
  stars     Int
  comment   String?
  userId    String
  carId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  car  Car  @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}

//============ Enums ============//

enum Role {
  USER
  ADMIN
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum CarType {
  SPORT_CAR
  HATCHBACK
  COUPE
  SEDAN
  CONVERTIBLE
  SUV
  STATION_WAGON
  MINIBUS
  VAN
  PICKUP
}

enum BookingStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum CarStatus {
  AVAILABLE
  UNAVAILABLE
}